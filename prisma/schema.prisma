generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String    @id @default(cuid())
  name         String?
  email        String    @unique
  passwordHash String?
  image        String?
  xp           Int       @default(0)
  level        Int       @default(1)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sessions      Session[]
  progress      LessonProgress[]
  quizAttempts  QuizAttempt[]
  bookmarks     Bookmark[]
  notes         Note[]
  streakDays    StreakDay[]
  achievements  UserAchievement[]
  certificates  Certificate[]

  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model LessonProgress {
  id          String    @id @default(cuid())
  userId      String
  moduleSlug  String
  lessonSlug  String
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleSlug, lessonSlug])
  @@map("lesson_progress")
}

model QuizAttempt {
  id          String   @id @default(cuid())
  userId      String
  quizId      String
  score       Int
  total       Int
  passed      Boolean
  answers     String
  xpEarned    Int      @default(0)
  completedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("quiz_attempts")
}

model Bookmark {
  id         String   @id @default(cuid())
  userId     String
  moduleSlug String
  lessonSlug String
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleSlug, lessonSlug])
  @@map("bookmarks")
}

model Note {
  id         String   @id @default(cuid())
  userId     String
  moduleSlug String
  lessonSlug String
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleSlug, lessonSlug])
  @@map("notes")
}

model StreakDay {
  id        String   @id @default(cuid())
  userId    String
  date      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("streak_days")
}

model Achievement {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  icon        String
  xpReward    Int      @default(0)
  rarity      String   @default("COMMON")

  users UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  earnedAt      DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

model Certificate {
  id         String   @id @default(cuid())
  userId     String
  moduleSlug String
  publicId   String   @unique @default(cuid())
  issuedAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleSlug])
  @@map("certificates")
}
